# Copy this to supabase/functions/.env for local `supabase functions serve` testing.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# For production, don't put the key in a file at all - set it with:
#   supabase secrets set GROQ_API_KEY=your-key-here
# SUPABASE_URL and SUPABASE_ANON_KEY are injected automatically by the Edge Functions
# runtime (both locally and in production) - you never need to set those yourself.
